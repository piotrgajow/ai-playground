{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "play-random.sh ${CLAUDE_PLUGIN_ROOT}/_sounds/startup"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "play-random.sh ${CLAUDE_PLUGIN_ROOT}/_sounds/attention-needed"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "play-random.sh ${CLAUDE_PLUGIN_ROOT}/_sounds/task-completed"
          }
        ]
      }
    ]
  }
}
